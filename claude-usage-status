#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# Claude Usage Status - Non-blocking caching wrapper for statusline
# ═══════════════════════════════════════════════════════════════════════════════
# Caches usage-fetch output for 3 minutes to avoid hammering the API
# NEVER BLOCKS - returns immediately, refreshes in background if stale
# Output format: 5h:45%:2h30m|7d:70%:3d12h
# On error: ERROR
# ═══════════════════════════════════════════════════════════════════════════════

# Detect script location to find usage-fetch directory
# Resolve symlinks for proper path detection (realpath not available on stock macOS)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd -P)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd -P)"
USAGE_FETCH_DIR="$SCRIPT_DIR/usage-fetch"
SCRIPT_PATH="$USAGE_FETCH_DIR/script.py"

# Use user-specific cache directory (not world-readable /tmp)
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude-code"
mkdir -p "$CACHE_DIR" 2>/dev/null
CACHE_FILE="$CACHE_DIR/usage-cache"
LOCK_DIR="$CACHE_DIR/usage-cache.lock"  # Use directory for atomic locking
CACHE_MAX_AGE=180  # 3 minutes in seconds
STALE_LOCK_AGE=60  # Remove locks older than 60 seconds

# Cross-platform function to get file modification time (works on Linux and macOS)
get_mtime() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        stat -f %m "$1" 2>/dev/null || echo 0
    else
        stat -c %Y "$1" 2>/dev/null || echo 0
    fi
}

# Function to fetch data (runs in background)
fetch_usage() {
    # Atomic lock using mkdir (prevents TOCTOU race condition)
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        # Lock exists - check if it's stale
        if [ -d "$LOCK_DIR" ]; then
            lock_age=$(($(date +%s) - $(get_mtime "$LOCK_DIR")))
            if [ "$lock_age" -gt "$STALE_LOCK_AGE" ]; then
                # Stale lock - remove it and try again
                rmdir "$LOCK_DIR" 2>/dev/null
                if ! mkdir "$LOCK_DIR" 2>/dev/null; then
                    return  # Another process got the lock
                fi
            else
                return  # Lock is fresh, another process is fetching
            fi
        else
            return
        fi
    fi

    # Check if script exists
    if [ ! -f "$SCRIPT_PATH" ]; then
        echo "ERROR" > "$CACHE_FILE"
        rmdir "$LOCK_DIR" 2>/dev/null
        return
    fi

    # Try uv first, fall back to python
    # Always cd to USAGE_FETCH_DIR for consistent behavior
    if command -v uv &>/dev/null; then
        output=$(cd "$USAGE_FETCH_DIR" && uv run python "$SCRIPT_PATH" --statusline 2>/dev/null)
    else
        output=$(cd "$USAGE_FETCH_DIR" && python3 "$SCRIPT_PATH" --statusline 2>/dev/null)
    fi

    if [ -n "$output" ]; then
        echo "$output" > "$CACHE_FILE"
    else
        echo "ERROR" > "$CACHE_FILE"
    fi

    rmdir "$LOCK_DIR" 2>/dev/null
}

# Check cache age
cache_age=999999
if [ -f "$CACHE_FILE" ]; then
    cache_age=$(($(date +%s) - $(get_mtime "$CACHE_FILE")))
fi

# If cache is fresh, just return it
if [ "$cache_age" -lt "$CACHE_MAX_AGE" ]; then
    cat "$CACHE_FILE"
    exit 0
fi

# Cache is stale or missing - return stale cache (if exists) and refresh in background
if [ -f "$CACHE_FILE" ]; then
    cat "$CACHE_FILE"
fi

# Kick off background refresh (fully detached, won't block)
fetch_usage </dev/null >/dev/null 2>&1 &
disown
